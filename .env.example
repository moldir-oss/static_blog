# Hugo Configuration
# Copy this file to .env and fill in your values
# For local development: hugo server --environment development

# Base URL of your site (required for production builds)
# GitHub Pages: https://your-username.github.io/your-repo-name
# Netlify: https://your-site-name.netlify.app
# Cloudflare Pages: https://your-project.pages.dev
# Custom domain: https://your-domain.com
HUGO_BASEURL=https://example.com

# Author name displayed in posts and metadata
HUGO_AUTHOR=Votre Nom

# Cusdis Comments (optional)
# Get your App ID from https://cusdis.com
CUSDIS_APP_ID=

# Social Links
GITHUB_URL=https://github.com/your-username
EMAIL_URL=mailto:your@email.com

# Analytics (optional)
# GOOGLE_ANALYTICS=G-XXXXXXXXXX

# Deployment Secrets (set these in your platform's dashboard, not in .env)
# NETLIFY_AUTH_TOKEN=
# NETLIFY_SITE_ID=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_PROJECT_NAME=
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=