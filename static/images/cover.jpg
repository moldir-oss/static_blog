<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630">
  <rect width="1200" height="630" fill="#1a1a2e"/>
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#16213e;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0f3460;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#grad)"/>
  <circle cx="600" cy="315" r="120" fill="#c0392b" opacity="0.2"/>
  <circle cx="600" cy="315" r="80" fill="#c0392b" opacity="0.4"/>
  <circle cx="600" cy="315" r="40" fill="#c0392b"/>
  <text x="600" y="330" font-family="system-ui, sans-serif" font-size="48" font-weight="bold" fill="white" text-anchor="middle">Mon Licenciement</text>
  <text x="600" y="380" font-family="system-ui, sans-serif" font-size="24" fill="#bdc3c7" text-anchor="middle">Parcours complet : de l'avertissement à la décision de justice</text>
  <text x="600" y="550" font-family="system-ui, sans-serif" font-size="16" fill="#7f8c8d" text-anchor="middle">Documentation • Transparence • Mémoire</text>
</svg>